# Optional: global refresh override (seconds) for ALL cards.
# Leave unset to use per-card defaults (see README)
# REFRESH_INTERVAL=3600

WEATHER_CITY=Lisbon
BUIENALARM_POSTCODE=1234AB

ANTHROPIC_ADMIN_API_KEY=sk-ant-admin-...

# Claude Quota card — copy accessToken / refreshToken from ~/.claude/.credentials.json
CLAUDE_OAUTH_TOKEN=sk-ant-oat01-...
CLAUDE_REFRESH_TOKEN=sk-ant-ort01-...

# WORLD_CLOCK_LOCAL_CITY=Amsterdam
WORLD_CLOCK_TZ1=America/New_York
WORLD_CLOCK_TZ2=Asia/Tokyo
WORLD_CLOCK_TZ3=Europe/London
WORLD_CLOCK_TZ4=Australia/Sydney
# WORLD_CLOCK_CITY1=New York
# WORLD_CLOCK_CITY2=Tokyo
# WORLD_CLOCK_CITY3=London
# WORLD_CLOCK_CITY4=Sydney

ICAL_URL_1=https://calendar.google.com/calendar/ical/...
ICAL_URL_2=https://calendar.google.com/calendar/ical/...

SHELL_HOST=192.168.x.x
SHELL_PORT=4568

# Set to false to hide on-screen log lines (launch/fetch/sleep messages on eips row 0)
# KDASH_DEBUG=false

# KINDLE_MOUNT=/run/media/youruser/Kindle1
